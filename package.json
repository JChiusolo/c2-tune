    "client": "vite --port 5173"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.52.0",
    "@aws-sdk/client-dynamodb": "3.600.0",
    "@aws-sdk/client-sfn": "3.600.0",
    "@aws-sdk/lib-dynamodb": "3.600.0",
    "concurrently": "8.2.2",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.0",
    "express-rate-limit": "7.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.1",
    "vite": "5.4.1"
