# ─── C Tunes Calibration Agent — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Required. Powers both the calibration agent and the λ Extract Lambda.
# One key covers both. Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── AWS — CSV Pipeline Integration ────────────────────────────────────────────
# Required for the "Export to VCM Editor" feature.
# Values come from Terraform outputs after running `terraform apply`.

# API Gateway invoke URL (from Terraform output: api_gateway_url)
AWS_API_GATEWAY_URL=https://abc123.execute-api.us-east-1.amazonaws.com/prod

# API Gateway key value (from API Gateway console → API Keys)
AWS_API_GATEWAY_KEY=your-api-gateway-key-value

# Step Functions state machine ARN (from Terraform output: state_machine_arn)
AWS_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:vcm-pipeline-prod

# DynamoDB table name for job status polling (from Terraform output: dynamodb_table_name)
AWS_DYNAMODB_TABLE=vcm-pipeline-jobs-prod

# AWS region (must match where you ran terraform apply)
AWS_REGION=us-east-1

# ── Email Notifications ────────────────────────────────────────────────────────
# Must be a verified SES identity. See AWS Console → SES → Verified Identities.
NOTIFICATION_EMAIL=your@businessemail.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
